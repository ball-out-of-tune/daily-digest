# ===========================================
# Daily Digest 配置文件
# 复制为 .env 并填入你的信息
# ===========================================

# --- Gmail SMTP (发件邮箱) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=yourname@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_TO=recipient@email.com

# --- DeepSeek API (AI 策展) ---
DEEPSEEK_KEY=sk-your-deepseek-api-key
